{
  "expo": {
    "name": "SleepWave",
    "slug": "SleepWave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0510"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hiroetc.sleepwave"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4f0c28"
      },
      "package": "com.hiroetc.sleepwave",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Uyku sesleri için izin gerekiyor."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4f0c28",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f81f5bc7-2715-4a15-bef5-12047f26c116"
      }
    }
  }
}
