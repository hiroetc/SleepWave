{
  "expo": {
    "name": "SleepWave",
    "slug": "SleepWave",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#171219"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.hiroetc.sleepwave"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#171219"
      },
      "package": "com.hiroetc.sleepwave",
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_HEALTH",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.WAKE_LOCK"
      ],
      "foregroundService": {
        "notificationTitle": "SleepWave",
        "notificationBody": "Uyku takibi devam ediyor...",
        "notificationColor": "#171219"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-av",
        {
          "microphonePermission": "Uyku sesleri için izin gerekiyor."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#3d2a40"
        }
      ],
      [
        "expo-task-manager"
      ],
      [
        "expo-background-fetch"
      ],
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "f81f5bc7-2715-4a15-bef5-12047f26c116"
      }
    }
  }
}
